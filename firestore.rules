rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ✅ Allow public read for delivery radius (no login required)
    match /adminSettings/{document} {
      allow read: if true;
    }

    // Rest all requires auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
